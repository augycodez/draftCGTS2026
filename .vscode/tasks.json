{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Edge with remote debugging",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-Command",
        "$workspace = (Get-Location).Path; Start-Process msedge.exe -ArgumentList @('--remote-debugging-port=9222', \"--user-data-dir=$workspace\\.vscode\\edge-debug-profile\", \"$workspace\\index.html\")"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
